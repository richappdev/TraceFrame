# Copy to apps/web/.env.local for local preview

# Bangumi OAuth (register at https://bgm.tv/dev/app)
# IMPORTANT: register EVERY callback URL you use (local + the Firebase Hosting URL) on bgm.tv/dev/app.
# Login uses the current request origin as redirect_uri when possible; BANGUMI_REDIRECT_URI is the fallback/default.
# or Bangumi returns: {"error":"invalid_uri","error_description":"No redirect URI was supplied or stored"}
BANGUMI_CLIENT_ID=
BANGUMI_CLIENT_SECRET=
BANGUMI_REDIRECT_URI=https://antiable-traceframe.web.app/api/auth/callback
# Optional override of identifying UA
# BANGUMI_USER_AGENT=antiable/trip (0.1.0) (https://example.com)

# Session encryption (32+ char random string)
SESSION_SECRET=dev-only-change-me-to-a-long-random-string

# Presence SQLite path (defaults to ../../data/presence.sqlite from apps/web)
# PRESENCE_DB=

# Firebase Analytics (public web-app config; leave blank to disable analytics)
# Firebase console -> Project settings -> Your apps -> Web app / SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=antiable-traceframe.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=antiable-traceframe
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
