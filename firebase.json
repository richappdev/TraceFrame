{
  "hosting": {
    "site": "antiable-traceframe",
    "public": "hosting-public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "traceframe-web",
          "region": "asia-east1",
          "pinTag": true
        }
      }
    ]
  }
}
